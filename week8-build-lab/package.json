{
  "name": "week8-build-lab",
  "version": "1.0.0",
  "description": "Build tools lab for WDDM 126",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "clean": "rd /s /q dist || rm -rf dist",
    "copy:html": "if not exist dist mkdir dist && copy src\\index.html dist\\index.html",
    "build:css": "cleancss src/style.css -o dist/style.min.css",
    "build:js": "terser src/script.js -o dist/script.min.js",
    "build": "npm-run-all clean copy:html build:css build:js"
  },
  "keywords": [],
  "author": "Gurneet Singh Saini",
  "license": "ISC",
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "npm-run-all": "^4.1.5",
    "terser": "^5.46.1"
  }
}
